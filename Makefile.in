Makefile: Makefile.in config.status
	./config.status

config.status: configure
	./config.status --recheck

depend:
	echo "$(SRC_ROOT_DIR)/include_make/make_depend_list.per $(MAKEDEPEND_INCLUDE) "
	$(SRC_ROOT_DIR)/include_make/make_depend_list.perl \
 $(MAKEDEPEND_INCLUDE) > dependency_list.make

#include dependency_list.make


# Note on cpp processing for Fortran include files.
# The Fortran program should include files with *.inc,
# but the Fortran include files in RCS and the
# Fortran include files installed in the "include" directory
# should have the name *_inc.f .


.c.o:
	$(CC) $(CC_SWITCHES) -c $< -o $@

.f.o:
	$(F77) $(F77_SWITCHES) -c $< -o $@
#.f.o:
#	$(SRC_ROOT_DIR)/include_make/declare_expand.perl \
#           < $*.f > temp.tmp
#	$(FCPP) $(FCPP_DEFS) temp.tmp > $*_tmp.f
#	$(F77) $(F77_SWITCHES) $(F77_INCLUDE) -c $*_tmp.f
#	mv $*_tmp.o $*.o
#	@j=0 ; for i in $(F_MAINPROGS) \
#           ; do \
#              if [ "$*.f" = "$$i" ] ; then \
#                 j=1 \
#              ; fi \
#        ; done \
#        ; if [ "$$j" = "1" ] ; then \
#           echo "Will not archive the main program." \
#        ; else \
#           ar rv $(LIBRARY_NAME) $*.o \
#        ; fi

.f.expanded:
	$(SRC_ROOT_DIR)/include_make/declare_expand.perl \
           < $*.f > $*.expanded

.f.prj:
	sed_include=`cat sed_include.tmp` ; \
           $(FTNCHEK) $(FTNCHEK_STRICTNESS) \
           -project -noextern -library $$sed_include $<

# Accomodate people who spell correctly.
ftncheck: ftnchek

make_sed_include:
	echo "$(F77_INCLUDE)" | \
           sed -e "s/-I/-include=/g" > sed_include.tmp

